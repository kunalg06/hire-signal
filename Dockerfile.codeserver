FROM codercom/code-server:latest

# Install Node.js, npm, Python and dependencies
USER root
RUN apt-get update && apt-get install -y \
    nodejs \
    npm \
    python3 \
    python3-pip \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install official Claude Code CLI via npm
RUN npm install -g @anthropic-ai/claude-code

# Install Python dependencies
RUN pip3 install --break-system-packages anthropic requests

# Set workspace and log directory permissions
RUN mkdir -p /workspace /app/logs && chmod 777 /workspace /app/logs

USER coder

# Create config directory with HTTP-only settings
RUN mkdir -p ~/.config/code-server && \
    echo "bind-addr: 0.0.0.0:8080" > ~/.config/code-server/config.yaml && \
    echo "auth: none" >> ~/.config/code-server/config.yaml && \
    echo "cert: false" >> ~/.config/code-server/config.yaml

# Configure Claude CLI to only use haiku-4.5 model
RUN mkdir -p ~/.claude && \
    echo "model: claude-haiku-4-5-20251001" > ~/.claude/config.yaml && \
    echo "# Only haiku-4.5 model allowed in student environment" >> ~/.claude/config.yaml

# Set environment variable to restrict model selection
ENV CLAUDE_MODEL=claude-haiku-4-5-20251001

EXPOSE 8080
WORKDIR /workspace
